{
  "name": "phasmo-evidence-tracker-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop frontend for the Phasmophobia evidence tracker.",
  "packageManager": "pnpm@11.0.3",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
    "build": "tsc --noEmit && vite build",
    "build:rust": "cargo build --release --locked",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview --host 127.0.0.1",
    "desktop": "pnpm build && electron . --dist",
    "bundle": "pnpm bundle:win",
    "bundle:win": "pnpm build && pnpm build:rust && electron-builder --win portable --x64"
  },
  "build": {
    "appId": "dev.camcam.phasmo-evidence-tracker",
    "productName": "Phasmo Evidence Tracker",
    "compression": "normal",
    "npmRebuild": false,
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "target/release/phasmo_evidence_tracker.exe",
        "to": "backend/phasmo_evidence_tracker.exe"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  }
}
